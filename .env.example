# .env.example
# Plantilla de variables de entorno para Docker
# Copia este archivo a .env y llena los valores antes de ejecutar docker compose up

# --- Base de datos ---
DB_HOST=db          # nombre del servicio MySQL en docker-compose (no cambiar)
DB_NAME=siae_imss   # nombre de la base de datos
DB_USER=root        # usuario de MySQL
DB_PASS=            # contrasena de MySQL (pon la que quieras)

# --- URL base del sistema ---
# Debe terminar con / y coincidir con el Alias de Apache
URL_BASE=/ProgWeb/siae-imss/
